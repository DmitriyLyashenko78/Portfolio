transition: width 0.3s ease;\n}\n\n.navLink:hover {\n    color: var(--color-text, #f0f4ff);\n}\n\n.navLink:hover::after {\n    width: 100%;\n}\n\n/* Активная ссылка (можно добавить позже) */\n.navLink.active {\n    color: var(--color-text, #f0f4ff);\n}\n\n.navLink.active::after {\n    width: 100%;\n}\n\n@media (min-width: 768px) {\n    .nav {\n        display: block;\n    }\n}\n\n/* ============================================\n   ДЕЙСТВИЯ (КНОПКИ)\n   ============================================ */\n\n.actions {\n    display: none;\n    flex-shrink: 0;\n}\n\n@media (min-width: 768px) {\n    .actions {\n        display: block;\n    }\n}\n\n/* ============================================\n   БУРГЕР-МЕНЮ (МОБИЛКА)\n   ============================================ */\n\n.burger {\n    display: flex;\n    flex-direction: column;\n    gap: 6px;\n    padding: 8px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    transition: all 0.3s ease;\n    flex-shrink: 0;\n}\n\n.burgerLine {\n    display: block;\n    width: 24px;\n    height: 2px;\n    background: var(--color-text, #f0f4ff);\n    border-radius: 2px;\n    transition: all 0.3s ease;\n    transform-origin: center;\n}\n\n/* Анимация бургера при открытии */\n.burgerLineOpen1 {\n    transform: rotate(45deg) translate(5px, 6px);\n}\n\n.burgerLineOpen2 {\n    opacity: 0;\n}\n\n.burgerLineOpen3 {\n    transform: rotate(-45deg) translate(5px, -6px);\n}\n\n@media (min-width: 768px) {\n    .burger {\n        display: none;\n    }\n}\n\n/* ============================================\n   МОБИЛЬНОЕ МЕНЮ (OVERLAY)\n   ============================================ */\n\n.mobileMenu {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    z-index: -1;\n    background: var(--color-bg, #0a0e1a);\n    padding: 80px 20px 40px;\n    transform: translateX(100%);\n    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n    overflow-y: auto;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n}\n\n.mobileMenuOpen {\n    transform: translateX(0);\n}\n\n.mobileNav {\n    width: 100%;\n    max-width: 400px;\n    text-align: center;\n}\n\n.mobileNavList {\n    display: flex;\n    flex-direction: column;\n    gap: var(--spacing-3xl, 32px);\n    list-style: none;\n    padding: 0;\n    margin: 0;\n}\n\n.mobileNavLink {\n    font-size: var(--font-size-2xl, 24px);\n    font-weight: var(--font-weight-medium, 500);\n    color: var(--color-text-secondary, #94a3b8);\n    text-decoration: none;\n    transition: color 0.2s ease;\n    display: inline-block;\n    padding: 8px 0;\n}\n\n.mobileNavLink:hover {\n    color: var(--color-text, #f0f4ff);\n}\n\n.mobileNavAction {\n    margin-top: var(--spacing-2xl, 24px);\n}\n\n/* ============================================\n   АНИМАЦИЯ ПОЯВЛЕНИЯ\n   ============================================ */\n\n@keyframes fadeInDown {\n    from {\n        opacity: 0;\n        transform: translateY(-16px);\n    }\n    to {\n        opacity: 1;\n        transform: translateY(0);\n    }\n}\n\n.header {\n    animation: fadeInDown 0.6s ease;\n}\n```\n\n\n```css:D:/Incubator/projects/portfolio/src/styles/globals.css\n/* src/styles/globals.css */\n@import './variables.css';\n\n*,\n*::before,\n*::after {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\n/* 1.2 Убираем стандартные отступы у body */\nbody {\n    min-height: 100vh;\n    background: var(--color-bg, #0a0e1a); /* ← основной фон всего сайта */\n    color: var(--color-text, #1a1a2e);\n    line-height: 1.6;\n    -webkit-font-smoothing: antialiased;\n    -moz-osx-font-smoothing: grayscale;\n}\n\n/* 1.3 Убираем стандартные стили у списков */\nul,\nol {\n    list-style: none;\n}\n\n/* 1.4 Убираем подчёркивание у ссылок */\na {\n    color: inherit;\n    text-decoration: none;\n}\n\n/* 1.5 Наследуем шрифт для форм */\ninput,\nbutton,\ntextarea,\nselect {\n    font: inherit;\n    color: inherit;\n}\n\n/* 1.6 Убираем стандартную кнопку у butto